rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (matches Auth UID)
    // Fields:
    //   - uid: string (required, immutable)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - completedLessons: list of strings (required)
    //   - currentStreak: number (required)
    //   - xp: number (required)
    //   - hearts: number (required)
    //   - gems: number (required)
    //   - lastActiveDate: string (optional)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'xp', 'hearts', 'gems', 'currentStreak', 'completedLessons']) &&
             data.uid is string &&
             data.xp is number && data.xp >= 0 &&
             data.hearts is number && data.hearts >= 0 &&
             data.gems is number && data.gems >= 0 &&
             data.currentStreak is number && data.currentStreak >= 0 &&
             data.completedLessons is list &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('lastActiveDate' in data) || data.lastActiveDate is string);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
      allow delete: if false;
    }
  }
}
