{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User progress and profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's photo URL" },
        "completedLessons": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of completed lesson IDs"
        },
        "currentStreak": { "type": "number", "description": "Current daily streak" },
        "xp": { "type": "number", "description": "Experience points" },
        "hearts": { "type": "number", "description": "Remaining hearts" },
        "gems": { "type": "number", "description": "Remaining gems" },
        "lastActiveDate": { "type": "string", "description": "Last active date in YYYY-MM-DD format" }
      },
      "required": ["uid", "xp", "hearts", "gems", "currentStreak", "completedLessons"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles and progress"
    }
  }
}
